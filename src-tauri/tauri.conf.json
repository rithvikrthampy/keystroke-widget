{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KeystrokeTracker",
  "version": "0.0.16",
  "identifier": "com.user.keystroketracker",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "KeystrokeTracker",
        "width": 380,
        "height": 240,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "visible": true,
        "minWidth": 320,
        "minHeight": 200
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/rithvikrthampy/keystroke-widget/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMyQjk1RDc0NjNDNEQ0MzIKUldReTFNUmpkRjI1TWtjcUlTSGF4UVpKYm9FWUYyK2lBVWxNUzBhWnY1eWRlZlZLVndFNlowMTkK"
    }
  }
}